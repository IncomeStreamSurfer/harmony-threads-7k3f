---
import Base from '../../layouts/Base.astro';
import { getProductBySlug } from '../../lib/products';

const { slug } = Astro.params;
const product = slug ? await getProductBySlug(slug) : undefined;
if (!product) { return new Response('Not found', { status: 404 }); }

const siteUrl = (Astro.site?.toString() || '').replace(/\/$/, '');
const sizes = Array.from(new Set(product.variants.map((v) => v.size)));
const colors = Array.from(new Set(product.variants.map((v) => v.color)));

const productLd = { '@context': 'https://schema.org', '@type': 'Product', name: product.name, description: product.description, image: [product.image_url, ...product.gallery.map((g) => g.url)], sku: product.variants[0]?.sku, brand: { '@type': 'Brand', name: product.vendor }, offers: { '@type': 'Offer', url: `${siteUrl}/products/${product.slug}`, priceCurrency: product.currency, price: (product.price_pence / 100).toFixed(2), availability: 'https://schema.org/InStock', priceValidUntil: `${new Date().getFullYear() + 1}-12-31` }, aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: 127 } };
const breadcrumbLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl }, { '@type': 'ListItem', position: 2, name: 'Shop', item: `${siteUrl}/shop` }, { '@type': 'ListItem', position: 3, name: product.name, item: `${siteUrl}/products/${product.slug}` }] };
---
<Base
  title={product.seo_title || `${product.name} | MyStore`}
  description={product.seo_description || product.description}
  ogImage={product.image_url}
  ogType="product"
  structuredData={[productLd, breadcrumbLd]}
>
  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-10 lg:py-16">
    <nav aria-label="Breadcrumb" class="text-xs text-[var(--color-mute)] mb-8"><a href="/" class="link-underline">Home</a> / <a href="/shop" class="link-underline">Shop</a> / <span>{product.name}</span></nav>
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
      <div>
        <div class="aspect-[4/5] bg-[var(--color-line)]/60 overflow-hidden">
          <img id="hero-image" src={product.gallery[0]?.url || product.image_url} alt={product.image_alt} class="w-full h-full object-cover" />
        </div>
        <div class="grid grid-cols-4 gap-2 mt-2">
          {product.gallery.map((g) => (
            <button type="button" data-thumb={g.url} class="aspect-square overflow-hidden border border-[var(--color-line)] hover:border-[var(--color-ink)] transition"><img src={g.url} alt={g.alt} class="w-full h-full object-cover" /></button>
          ))}
        </div>
      </div>
      <div class="lg:pt-4">
        <p class="text-xs uppercase tracking-widest text-[var(--color-mute)]">{product.vendor} · {product.type}</p>
        <h1 class="font-display text-4xl sm:text-5xl tracking-tight mt-2">{product.name}</h1>
        <p class="mt-3 text-[var(--color-mute)] italic">{product.tagline}</p>
        <div class="mt-5 flex items-baseline gap-3">
          <span class="text-3xl font-semibold">£{(product.price_pence/100).toFixed(2)}</span>
          {product.compare_at_pence && product.compare_at_pence > product.price_pence && <span class="text-[var(--color-mute)] line-through">£{(product.compare_at_pence/100).toFixed(2)}</span>}
        </div>
        <form id="buy-form" class="mt-8 border-t border-[var(--color-line)] pt-8 space-y-6">
          {sizes.length > 0 && (
            <div>
              <label class="text-sm font-semibold">Size</label>
              <div class="flex flex-wrap gap-2 mt-2" data-group="size">
                {sizes.map((s, i) => (<button type="button" data-value={s} class={`size-btn px-4 py-2 border ${i===0 ? 'border-[var(--color-ink)] bg-[var(--color-ink)] text-white' : 'border-[var(--color-line)] hover:border-[var(--color-ink)]'} text-sm`}>{s}</button>))}
              </div>
            </div>
          )}
          {colors.length > 0 && (
            <div>
              <label class="text-sm font-semibold">Colour</label>
              <div class="flex flex-wrap gap-2 mt-2" data-group="color">
                {colors.map((c, i) => (<button type="button" data-value={c} class={`color-btn px-4 py-2 border ${i===0 ? 'border-[var(--color-ink)] bg-[var(--color-ink)] text-white' : 'border-[var(--color-line)] hover:border-[var(--color-ink)]'} text-sm capitalize`}>{c}</button>))}
              </div>
            </div>
          )}
          <div>
            <label class="text-sm font-semibold">Quantity</label>
            <div class="flex items-center gap-3 mt-2">
              <button type="button" class="qty-btn w-10 h-10 border border-[var(--color-line)]" data-step="-1">−</button>
              <input id="qty" type="number" min="1" max="10" value="1" class="w-16 h-10 text-center border border-[var(--color-line)]" />
              <button type="button" class="qty-btn w-10 h-10 border border-[var(--color-line)]" data-step="1">+</button>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <button type="submit" class="btn-primary flex-1 justify-center">Add to cart</button>
            <a href="/cart" class="btn-ghost flex-1 justify-center">Checkout →</a>
          </div>
          <p id="buy-msg" class="text-sm text-[var(--color-accent)]" style="min-height:1.25rem"></p>
        </form>
      </div>
    </div>
    <section class="mt-24 grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <h2 class="font-display text-3xl sm:text-4xl tracking-tight">About this product</h2>
        <div class="mt-6 space-y-5 text-[var(--color-ink)]/80 leading-relaxed">{product.long_description.map((para) => <p>{para}</p>)}</div>
      </div>
      <aside class="bg-[var(--color-paper)] border border-[var(--color-line)] p-6 h-fit">
        <h3 class="font-display text-xl">Why shoppers love it</h3>
        <ul class="mt-4 space-y-3 text-sm">{product.highlights.map((h) => (<li class="flex gap-3"><span class="w-2 h-2 mt-1.5 rounded-full bg-[var(--color-accent)] flex-shrink-0"></span><span>{h}</span></li>))}</ul>
      </aside>
    </section>
  </section>
  <script define:vars={{ productId: product.id, productName: product.name, productSlug: product.slug, productImage: product.image_url, pricePence: product.price_pence, sizes, colors, variantMap: product.variants.map(v => ({ sku: v.sku, size: v.size, color: v.color })) }}>
    document.querySelectorAll('[data-thumb]').forEach(btn => btn.addEventListener('click', () => { document.getElementById('hero-image').src = btn.dataset.thumb; }));
    let chosen = { size: sizes[0], color: colors[0] };
    function select(group, val) {
      chosen[group] = val;
      document.querySelectorAll(`[data-group="${group}"] button`).forEach(b => {
        const a = b.dataset.value === val;
        b.classList.toggle('bg-[var(--color-ink)]', a); b.classList.toggle('text-white', a); b.classList.toggle('border-[var(--color-ink)]', a);
      });
    }
    document.querySelectorAll('[data-group="size"] button').forEach(b => b.addEventListener('click', () => select('size', b.dataset.value)));
    document.querySelectorAll('[data-group="color"] button').forEach(b => b.addEventListener('click', () => select('color', b.dataset.value)));
    const qty = document.getElementById('qty');
    document.querySelectorAll('.qty-btn').forEach(b => b.addEventListener('click', () => { const step = parseInt(b.dataset.step, 10); qty.value = String(Math.max(1, Math.min(10, parseInt(qty.value || '1', 10) + step))); }));
    document.getElementById('buy-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const match = variantMap.find(v => v.size === chosen.size && v.color === chosen.color) || variantMap[0];
      const item = { product_id: productId, slug: productSlug, name: productName, sku: match.sku, variant: `Size: ${match.size} · Colour: ${match.color}`, price_pence: pricePence, image_url: productImage, qty: parseInt(qty.value || '1', 10) };
      const raw = localStorage.getItem('mystore_cart'); const items = raw ? JSON.parse(raw) : [];
      const existing = items.find(i => i.sku === item.sku); if (existing) existing.qty += item.qty; else items.push(item);
      localStorage.setItem('mystore_cart', JSON.stringify(items));
      document.dispatchEvent(new CustomEvent('cart:changed'));
      const msg = document.getElementById('buy-msg'); msg.textContent = `Added ${item.qty} × ${item.variant} to cart ✓`; msg.style.color = 'var(--color-ink)';
    });
  </script>
</Base>

---
import Base from '../layouts/Base.astro';
import { getAllProducts } from '../lib/products';

const products = await getAllProducts();
const siteUrl = (Astro.site?.toString() || '').replace(/\/$/, '');

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Shop all products',
  description: 'Browse every product at MyStore.',
  url: `${siteUrl}/shop`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: products.map((p, idx) => ({
      '@type': 'ListItem',
      position: idx + 1,
      url: `${siteUrl}/products/${p.slug}`,
      name: p.name,
    })),
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: `${siteUrl}/shop` },
  ],
};
---
<Base
  title="Shop All Products | MyStore"
  description="Browse every product at MyStore. Filter by category, price, and more. Free shipping available."
  structuredData={[itemListLd, breadcrumbLd]}
>
  <section class="border-b border-[var(--color-line)] bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-14 lg:py-20">
      <nav aria-label="Breadcrumb" class="text-xs text-[var(--color-mute)] mb-4"><a href="/" class="link-underline">Home</a> / <span>Shop</span></nav>
      <h1 class="font-display text-5xl sm:text-6xl tracking-tight">Shop all products</h1>
      <p class="mt-4 max-w-2xl text-[var(--color-mute)] leading-relaxed">
        This is the master catalogue — every item we currently stock. Looking for a theme? Browse our <a href="/collections" class="link-underline font-medium text-[var(--color-ink)]">curated collections</a>.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-14">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((p) => (
        <a href={`/products/${p.slug}`} class="group block">
          <div class="aspect-[4/5] bg-[var(--color-line)]/60 overflow-hidden relative">
            <img src={p.image_url} alt={p.image_alt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            {p.compare_at_pence && p.compare_at_pence > p.price_pence && (
              <span class="absolute top-3 left-3 bg-[var(--color-accent)] text-white text-xs px-2 py-1 font-semibold">SAVE £{((p.compare_at_pence - p.price_pence)/100).toFixed(0)}</span>
            )}
          </div>
          <div class="mt-4">
            <p class="text-xs uppercase tracking-widest text-[var(--color-mute)]">{p.vendor} · {p.type}</p>
            <h2 class="font-display text-xl mt-1 leading-tight">{p.name}</h2>
            <p class="mt-1 text-[var(--color-mute)] text-sm line-clamp-2">{p.tagline}</p>
            <p class="mt-3"><span class="font-semibold">£{(p.price_pence/100).toFixed(2)}</span>
              {p.compare_at_pence && p.compare_at_pence > p.price_pence && (<span class="ml-2 text-sm text-[var(--color-mute)] line-through">£{(p.compare_at_pence/100).toFixed(2)}</span>)}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

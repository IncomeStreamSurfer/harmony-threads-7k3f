---
import Base from '../layouts/Base.astro';

const siteUrl = (Astro.site?.toString() || '').replace(/\/$/, '');
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'MyStore',
  url: siteUrl,
  contactPoint: { '@type': 'ContactPoint', email: 'hello@mystore.example', contactType: 'customer support', availableLanguage: ['English'] },
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${siteUrl}/contact` },
  ],
};
---
<Base
  title="Contact Us | MyStore"
  description="Have a question? Contact MyStore's friendly support team. We're here to help with orders, returns, and anything else."
  structuredData={[orgLd, breadcrumbLd]}
>
  <section class="max-w-6xl mx-auto px-6 lg:px-10 py-16 lg:py-24 grid lg:grid-cols-5 gap-14">
    <div class="lg:col-span-2">
      <span class="chip">Say hi</span>
      <h1 class="mt-5 font-display text-5xl sm:text-6xl tracking-tight leading-[1.05]">Contact us — we're here to help.</h1>
      <p class="mt-5 text-[var(--color-mute)] leading-relaxed">
        Whether you have a question about an order, need help with sizing, or want to collaborate on a drop — we read every message and reply within 24 hours.
      </p>
      <dl class="mt-10 space-y-5 text-sm">
        <div><dt class="text-xs uppercase tracking-widest text-[var(--color-mute)]">Email</dt><dd class="mt-1"><a href="mailto:hello@mystore.example" class="link-underline font-medium">hello@mystore.example</a></dd></div>
        <div><dt class="text-xs uppercase tracking-widest text-[var(--color-mute)]">Studio</dt><dd class="mt-1 text-[var(--color-mute)]">Unit 4, Digbeth Quarter, Birmingham B5, UK</dd></div>
        <div><dt class="text-xs uppercase tracking-widest text-[var(--color-mute)]">Hours</dt><dd class="mt-1 text-[var(--color-mute)]">Mon–Fri · 09:00 — 18:00 GMT</dd></div>
      </dl>
    </div>
    <form class="lg:col-span-3 bg-white border border-[var(--color-line)] p-8 lg:p-10 space-y-5" id="contact-form">
      <h2 class="font-display text-3xl">Send us a message</h2>
      <p class="text-[var(--color-mute)] text-sm">We'll get back to you within 24 hours.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        <label class="block text-sm"><span class="font-medium">Name</span><input name="name" required class="mt-1 w-full border border-[var(--color-line)] bg-white px-4 py-3 focus:outline-none focus:border-[var(--color-ink)]" /></label>
        <label class="block text-sm"><span class="font-medium">Email</span><input type="email" name="email" required class="mt-1 w-full border border-[var(--color-line)] bg-white px-4 py-3 focus:outline-none focus:border-[var(--color-ink)]" /></label>
      </div>
      <label class="block text-sm"><span class="font-medium">Topic</span><select name="topic" class="mt-1 w-full border border-[var(--color-line)] bg-white px-4 py-3"><option>Order help</option><option>Returns &amp; refunds</option><option>Sizing</option><option>Wholesale / collab</option></select></label>
      <label class="block text-sm"><span class="font-medium">Message</span><textarea name="message" rows="6" required class="mt-1 w-full border border-[var(--color-line)] bg-white px-4 py-3"></textarea></label>
      <button class="btn-primary w-full justify-center">Send message</button>
      <p id="contact-msg" class="text-sm text-[var(--color-accent)]" style="min-height:1rem"></p>
    </form>
  </section>
  <script>
    document.getElementById('contact-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.currentTarget;
      const data = Object.fromEntries(new FormData(f).entries());
      const msg = document.getElementById('contact-msg'); msg.textContent = 'Sending…';
      try {
        const r = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        if (r.ok) { msg.style.color='var(--color-ink)'; msg.textContent='Thanks — message received.'; f.reset(); }
        else { const j = await r.json().catch(()=>({})); msg.textContent = j.error || 'Could not send.'; }
      } catch { msg.textContent = 'Network error — please try again.'; }
    });
  </script>
</Base>

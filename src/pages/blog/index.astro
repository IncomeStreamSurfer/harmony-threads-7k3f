---
import Base from '../../layouts/Base.astro';
import { supabase, sbOk } from '../../lib/supabase';

let posts = [];
if (sbOk()) {
  const { data } = await supabase
    .from('content')
    .select('slug, title, excerpt, cover_image_url, published_at, tags')
    .not('published_at', 'is', null)
    .order('published_at', { ascending: false })
    .limit(30);
  posts = data || [];
}

const siteUrl = (Astro.site?.toString() || '').replace(/\/$/, '');
const blogLd = { '@context': 'https://schema.org', '@type': 'Blog', name: 'The MyStore Journal', url: `${siteUrl}/blog`, description: 'Product guides, tips, and inspiration from the MyStore team.' };
const breadcrumbLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl }, { '@type': 'ListItem', position: 2, name: 'Journal', item: `${siteUrl}/blog` }] };
---
<Base
  title="Blog | MyStore"
  description="Read the MyStore blog for product guides, tips, and inspiration. New articles published regularly."
  structuredData={[blogLd, breadcrumbLd]}
>
  <section class="border-b border-[var(--color-line)] bg-white">
    <div class="max-w-5xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
      <span class="chip">Journal</span>
      <h1 class="mt-5 font-display text-5xl sm:text-6xl tracking-tight">The MyStore Journal.</h1>
      <p class="mt-5 max-w-2xl text-[var(--color-mute)] leading-relaxed">Product guides, tips, and inspiration from the studio. New pieces published regularly.</p>
    </div>
  </section>
  <section class="max-w-6xl mx-auto px-6 lg:px-10 py-16">
    {posts.length === 0 ? (
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <span class="chip">Coming soon</span>
          <h2 class="mt-4 font-display text-4xl tracking-tight">Fresh articles on the way.</h2>
          <p class="mt-4 text-[var(--color-mute)] leading-relaxed">We're working on a handful of pieces. Drop your email and we'll send the first one.</p>
          <form class="mt-8 flex flex-col sm:flex-row gap-2 max-w-md" data-newsletter>
            <input type="email" name="email" required placeholder="you@domain.com" class="flex-1 border border-[var(--color-line)] bg-white px-4 py-3" />
            <button class="btn-primary">Join the list</button>
          </form>
          <div class="mt-10 grid grid-cols-2 gap-4 text-sm">
            <a href="/shop" class="border border-[var(--color-line)] bg-white p-5 hover:border-[var(--color-ink)] transition"><p class="font-semibold">Browse the shop →</p></a>
            <a href="/collections" class="border border-[var(--color-line)] bg-white p-5 hover:border-[var(--color-ink)] transition"><p class="font-semibold">Browse collections →</p></a>
          </div>
        </div>
        <div class="hidden lg:block"><img src="https://images.unsplash.com/photo-1519681393784-d120267933ba?auto=format&fit=crop&w=900&q=80" alt="Notebooks on a desk" class="w-full h-[520px] object-cover" /></div>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((p) => (
          <a href={`/blog/${p.slug}`} class="group block border border-[var(--color-line)] bg-white hover:border-[var(--color-ink)] transition">
            {p.cover_image_url ? <div class="aspect-[4/3] overflow-hidden"><img src={p.cover_image_url} alt={p.title} class="w-full h-full object-cover" /></div> : <div class="aspect-[4/3] bg-gradient-to-br from-[var(--color-paper)] to-[var(--color-line)]"></div>}
            <div class="p-6">
              <p class="text-xs uppercase tracking-widest text-[var(--color-mute)]">{p.published_at ? new Date(p.published_at).toLocaleDateString('en-GB', { year:'numeric', month:'short', day:'numeric' }) : ''}</p>
              <h2 class="font-display text-2xl mt-2 leading-tight">{p.title}</h2>
              {p.excerpt && <p class="mt-3 text-sm text-[var(--color-mute)] line-clamp-3">{p.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Base>

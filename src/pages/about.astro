---
import Base from '../layouts/Base.astro';

const siteUrl = (Astro.site?.toString() || '').replace(/\/$/, '');
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'MyStore',
  url: siteUrl,
  foundingDate: '2023-01-01',
  description: 'A curated online shop offering quality products — graphic apparel, music-inspired goods and everyday essentials.',
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${siteUrl}/about` },
  ],
};
---
<Base
  title="About Us | MyStore"
  description="Learn about MyStore — our story, mission, and commitment to quality. We're passionate about bringing great products to you."
  structuredData={[orgLd, breadcrumbLd]}
>
  <section class="relative border-b border-[var(--color-line)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-20 lg:py-28 grid lg:grid-cols-2 gap-14 items-center">
      <div>
        <nav aria-label="Breadcrumb" class="text-xs text-[var(--color-mute)] mb-4"><a href="/" class="link-underline">Home</a> / <span>About</span></nav>
        <span class="chip">Our story</span>
        <h1 class="mt-5 font-display text-5xl sm:text-6xl tracking-tight leading-[1.05]">About MyStore.</h1>
        <p class="mt-6 text-lg text-[var(--color-mute)] leading-relaxed max-w-xl">
          We're a small, opinionated team obsessed with finding things worth owning — and making the act of buying them feel a little more like discovery, and a little less like online shopping.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/shop" class="btn-primary">See what we make →</a>
          <a href="/contact" class="btn-ghost">Get in touch</a>
        </div>
      </div>
      <div class="relative">
        <img src="https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?auto=format&fit=crop&w=900&q=80" alt="Our studio workspace" class="w-full h-[520px] object-cover" />
        <div class="absolute -bottom-6 -left-6 bg-[var(--color-accent)] text-white px-6 py-5 shadow-xl">
          <p class="font-display text-2xl">Since 2023</p>
          <p class="text-sm opacity-90">Shipped to 24 countries</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 lg:px-10 py-20 space-y-8 text-[var(--color-ink)]/85 leading-relaxed">
    <h2 class="font-display text-4xl tracking-tight">How this all started.</h2>
    <p>MyStore began in the back of a Birmingham record shop. Three of us — a graphic designer, a copywriter, and a software engineer whose loft was full of band merch — kept having the same conversation: <em>why is it so hard to find well-made basics with a bit of personality?</em></p>
    <p>We started by printing a batch of 40 graphic tees. They sold out in a weekend. Everything you see on the shop today has passed that test. If it's here, it's here because someone on our team wears it, carries it, or has quietly ordered a second one for a friend.</p>

    <h2 class="font-display text-4xl tracking-tight pt-8">What we care about.</h2>
    <div class="grid md:grid-cols-3 gap-6 not-prose">
      <div class="border border-[var(--color-line)] bg-white p-6">
        <h3 class="font-display text-xl">Small-batch quality</h3>
        <p class="mt-3 text-[var(--color-mute)]">We'd rather make 200 great pieces than 2,000 mediocre ones.</p>
      </div>
      <div class="border border-[var(--color-line)] bg-white p-6">
        <h3 class="font-display text-xl">Honest materials</h3>
        <p class="mt-3 text-[var(--color-mute)]">100% cotton where it makes sense. We list the fabric weight on every product page.</p>
      </div>
      <div class="border border-[var(--color-line)] bg-white p-6">
        <h3 class="font-display text-xl">Humans at the other end</h3>
        <p class="mt-3 text-[var(--color-mute)]">We answer emails ourselves. We pack orders ourselves. No chatbots.</p>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-ink)] text-[var(--color-paper)]">
    <div class="max-w-5xl mx-auto px-6 lg:px-10 py-20 text-center">
      <h2 class="font-display text-4xl sm:text-5xl tracking-tight">Let's make something you'll keep wearing.</h2>
      <p class="mt-4 opacity-80 max-w-xl mx-auto">We release a new colourway or print most months. Sign up to hear about drops first — no spam.</p>
      <form class="mt-8 flex flex-col sm:flex-row gap-2 max-w-lg mx-auto" data-newsletter>
        <input type="email" name="email" required placeholder="you@domain.com" class="flex-1 bg-transparent border border-white/30 text-white placeholder:text-white/50 px-4 py-3 focus:outline-none focus:border-white" />
        <button class="btn-primary !bg-[var(--color-accent)]">Join the list</button>
      </form>
    </div>
  </section>
</Base>

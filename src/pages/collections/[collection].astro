---
import Base from '../../layouts/Base.astro';
import { COLLECTIONS, getCollection } from '../../lib/products';

const { collection } = Astro.params;
const meta = COLLECTIONS.find((c) => c.slug === collection);
if (!meta) { return new Response('Not found', { status: 404 }); }
const products = await getCollection(collection || '');
const others = COLLECTIONS.filter((c) => c.slug !== collection);
const siteUrl = (Astro.site?.toString() || '').replace(/\/$/, '');

const collLd = { '@context': 'https://schema.org', '@type': 'CollectionPage', name: meta.name, url: `${siteUrl}/collections/${meta.slug}`, mainEntity: { '@type': 'ItemList', itemListElement: products.map((p, i) => ({ '@type': 'ListItem', position: i + 1, url: `${siteUrl}/products/${p.slug}`, name: p.name })) } };
const breadcrumbLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl }, { '@type': 'ListItem', position: 2, name: 'Collections', item: `${siteUrl}/collections` }, { '@type': 'ListItem', position: 3, name: meta.name, item: `${siteUrl}/collections/${meta.slug}` }] };
---
<Base
  title={`${meta.name} | MyStore`}
  description={meta.tagline}
  ogImage={meta.hero}
  structuredData={[collLd, breadcrumbLd]}
>
  <section class="relative overflow-hidden border-b border-[var(--color-line)]">
    <div class="absolute inset-0 -z-10">
      <img src={meta.hero} alt={`${meta.name} collection hero`} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-20 lg:py-28 text-white">
      <span class="chip !bg-white/10 !border-white/30 !text-white/80">{products.length} products</span>
      <h1 class="mt-4 font-display text-5xl sm:text-6xl lg:text-7xl tracking-tight max-w-3xl">{meta.name}</h1>
      <p class="mt-5 max-w-2xl text-white/90 leading-relaxed text-lg">{meta.tagline}</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-14 lg:py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((p) => (
        <a href={`/products/${p.slug}`} class="group block">
          <div class="aspect-[4/5] bg-[var(--color-line)]/60 overflow-hidden relative">
            <img src={p.image_url} alt={p.image_alt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            {p.compare_at_pence && p.compare_at_pence > p.price_pence && (<span class="absolute top-3 left-3 bg-[var(--color-accent)] text-white text-xs px-2 py-1 font-semibold">SAVE £{((p.compare_at_pence - p.price_pence)/100).toFixed(0)}</span>)}
          </div>
          <div class="mt-4">
            <p class="text-xs uppercase tracking-widest text-[var(--color-mute)]">{p.vendor}</p>
            <h2 class="font-display text-xl mt-1">{p.name}</h2>
            <p class="mt-1 text-sm text-[var(--color-mute)] line-clamp-2">{p.tagline}</p>
            <p class="mt-3 font-semibold">£{(p.price_pence/100).toFixed(2)}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
  <section class="border-t border-[var(--color-line)] bg-[var(--color-paper)]">
    <div class="max-w-5xl mx-auto px-6 lg:px-10 py-16 grid md:grid-cols-2 gap-10 items-center">
      <div><h2 class="font-display text-3xl sm:text-4xl tracking-tight">Keep exploring.</h2><p class="mt-4 text-[var(--color-mute)] leading-relaxed">Every piece in our {meta.name.toLowerCase()} is hand-picked. Check our other collections below.</p></div>
      <div class="grid grid-cols-3 gap-3">
        {others.map((o) => (
          <a href={`/collections/${o.slug}`} class="relative aspect-square overflow-hidden group block">
            <img src={o.hero} alt={o.name} class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-black/40"></div>
            <p class="absolute inset-0 flex items-center justify-center text-white font-display text-lg">{o.name}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
